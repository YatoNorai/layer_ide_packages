diff --git a/packages/termux-tools/build.sh b/packages/termux-tools/build.sh
--- a/packages/termux-tools/build.sh
+++ b/packages/termux-tools/build.sh
@@ -26,2 +26,15 @@ termux_step_pre_configure() {
 	autoreconf -vfi
 }
+
+termux_step_post_make_install() {
+	# Layer IDE does not ship regional mirror directories.
+	# Without this fix, every `pkg install` prints a warning and runs
+	# failing `find` commands for asia/, chinese_mainland/, europe/, etc.
+	#
+	# IMPORTANT: We surgically remove only the echo and mirrors+=(find...)
+	# lines. We do NOT use a range-delete (/start/,/end/d) because that
+	# would also delete the closing `fi`, breaking bash syntax in pkg.
+	local pkg_bin="${TERMUX_PREFIX}/bin/pkg"
+	# Remove: echo "No mirror or mirror group selected..." warning line
+	sed -i '/No mirror or mirror group selected/d' "${pkg_bin}"
+	# Remove: mirrors+=($(find .../{asia,chinese_mainland,...}/)) lines in
+	# both the broken-symlink elif branch and the no-mirror else branch.
+	sed -i '/mirrors+=.*find.*{asia,chinese_mainland,europe,north_america,oceania,russia}/d' "${pkg_bin}"
+}
