diff --git a/packages/termux-tools/build.sh b/packages/termux-tools/build.sh
--- a/packages/termux-tools/build.sh
+++ b/packages/termux-tools/build.sh
@@ -26,2 +26,31 @@ termux_step_pre_configure() {
 	autoreconf -vfi
 }
+
+termux_step_post_make_install() {
+	# ── Fix 1: Surgical removal of mirror-warning and broken find commands ──
+	# Layer IDE does not ship regional mirror directories (asia/, europe/, etc.).
+	# Without this fix, every `pkg install` prints a warning and runs failing
+	# `find` commands. We remove only the specific offending lines — NOT a
+	# range-delete that would also remove the closing `fi` and break bash syntax.
+	local pkg_bin="${TERMUX_PREFIX}/bin/pkg"
+	# Remove the "No mirror or mirror group selected" echo line
+	sed -i '/No mirror or mirror group selected/d' "${pkg_bin}"
+	# Remove mirrors+=($(find .../{asia,chinese_mainland,...}/)) in elif and else
+	sed -i '/mirrors+=.*find.*{asia,chinese_mainland,europe,north_america,oceania,russia}/d' "${pkg_bin}"
+
+	# ── Fix 2: Install Layer IDE default mirror ──
+	# The pkg script reads MIRROR_BASE_DIR/default to get the repository URL and
+	# writes it to sources.list on every `pkg install`. Since mirrors/ is excluded
+	# from the build (termux-tools-mirrors.patch removes it from SUBDIRS), the
+	# default file is never installed and pkg fails with:
+	#   "Error: None of the mirrors are accessible" → exit 1
+	#
+	# We install a minimal default mirror file pointing to the Layer IDE repo so
+	# that pkg can always resolve the correct repository URL.
+	mkdir -p "${TERMUX_PREFIX}/etc/termux/mirrors"
+	cat > "${TERMUX_PREFIX}/etc/termux/mirrors/default" << 'EOF'
+# This file is sourced by pkg
+# Layer IDE package repository — auto-generated by build
+WEIGHT=10
+MAIN="@COTG_REPO@"
+EOF
+}
